# Orchestra configuration for Covoiturage
# Source this before running orch: source .env.orchestra

export ORCH_WORKERS="backend frontend tester pm"
export ORCH_BRANCH_PREFIX="orch"
export ORCH_STAGGER=10
export ORCH_POLL_INTERVAL=5
export ORCH_TASK_TIMEOUT=600
export ORCH_MERGE_ORDER="pm backend frontend tester"

# Default: all workers use codex
export ORCH_WORKER_CMD="codex"
export ORCH_WORKER_FLAGS="--dangerously-bypass-approvals-and-sandbox"

# PM override: uses Claude Sonnet (cheaper, good for specs/stories)
export ORCH_WORKER_CMD_pm="claude"
export ORCH_WORKER_FLAGS_pm="--model sonnet --dangerously-skip-permissions"
