{
  "name": "covoiturage",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "vitest run --config vitest.config.ts",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "pnpm --filter @covoiturage/db push",
    "db:seed": "pnpm --filter @covoiturage/db seed",
    "db:studio": "pnpm --filter @covoiturage/db studio"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
